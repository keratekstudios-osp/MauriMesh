{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MauriMesh API Contract",
  "version": "1.0.0",
  "baseUrl": "/api",
  "description": "All endpoints served by artifacts/api-server. Paths are relative to /api. The shared reverse proxy mounts all traffic at /api.",
  "endpoints": [
    {
      "id": "health",
      "method": "GET",
      "path": "/healthz",
      "description": "API liveness check.",
      "auth": "none",
      "request": null,
      "response": {
        "status": 200,
        "body": { "status": "ok" }
      }
    },
    {
      "id": "auth.login",
      "method": "POST",
      "path": "/auth/login",
      "description": "Create a new session. Returns a 64-byte hex token and an auto-generated nodeId.",
      "auth": "none",
      "request": {
        "contentType": "application/json",
        "body": {
          "username": "string (required)"
        }
      },
      "response": {
        "status": 200,
        "body": {
          "ok": true,
          "token": "string (64-char hex)",
          "nodeId": "string (node-<uuid>)",
          "username": "string",
          "expiresAt": "ISO 8601 date string (7 days from now)"
        }
      },
      "errorResponse": {
        "status": 400,
        "body": { "ok": false, "error": "username required" }
      }
    },
    {
      "id": "auth.verify",
      "method": "POST",
      "path": "/auth/verify",
      "description": "Verify an existing session token.",
      "auth": "Bearer token",
      "request": null,
      "response": {
        "status": 200,
        "body": {
          "ok": true,
          "nodeId": "string",
          "username": "string",
          "expiresAt": "ISO 8601 date string"
        }
      },
      "errorResponse": {
        "status": 401,
        "body": { "ok": false, "error": "Invalid or expired token" }
      }
    },
    {
      "id": "auth.logout",
      "method": "POST",
      "path": "/auth/logout",
      "description": "Invalidate the current session token.",
      "auth": "Bearer token",
      "request": null,
      "response": {
        "status": 200,
        "body": { "ok": true }
      }
    },
    {
      "id": "mesh.status",
      "method": "GET",
      "path": "/mesh/status",
      "description": "Returns current mesh topology. Returns LIVE data from DB when peers exist; falls back to SIMULATION when DB is empty.",
      "auth": "none",
      "request": null,
      "response": {
        "status": 200,
        "body": {
          "mode": "LIVE | SIMULATION",
          "message": "string",
          "nodeCount": "number",
          "routeCount": "number",
          "nodes": [
            {
              "id": "string",
              "label": "string",
              "status": "online | offline | relay",
              "signal": "number (0-100)",
              "hops": "number",
              "x": "number (canvas %)",
              "y": "number (canvas %)",
              "transport": "ble | wifi | sim",
              "jumpCode": "string | null",
              "lastSeen": "ISO 8601 date string | null"
            }
          ],
          "routes": [
            {
              "from": "string (node id)",
              "to": "string (node id)",
              "quality": "number (0-100)",
              "transport": "string | null"
            }
          ]
        }
      }
    },
    {
      "id": "mesh.peers.upsert",
      "method": "POST",
      "path": "/mesh/peers/upsert",
      "description": "Directly upsert a peer into the mesh_peers DB table.",
      "auth": "none",
      "request": {
        "contentType": "application/json",
        "body": {
          "id": "string (required)",
          "label": "string (optional)",
          "transport": "ble | wifi | sim (optional, default ble)",
          "status": "online | offline | relay (optional, default online)",
          "signal": "number 0-100 (optional, default 50)",
          "trust": "number 0-100 (optional, default 50)",
          "rssi": "number dBm (optional)",
          "latencyMs": "number (optional)",
          "jumpCode": "string (optional)"
        }
      },
      "response": {
        "status": 200,
        "body": { "ok": true }
      }
    },
    {
      "id": "ai.governance.status",
      "method": "GET",
      "path": "/mesh/ai-governance/status",
      "description": "Returns current AI mesh engine snapshot (in-memory peer registry, routing stats).",
      "auth": "none",
      "request": null,
      "response": {
        "status": 200,
        "body": {
          "ok": true,
          "truth": "string",
          "snapshot": {
            "mode": "HYBRID | BLE | WIFI | STORE_FORWARD",
            "localNodeId": "string",
            "message": "string",
            "peers": "object[]",
            "stats": "object"
          }
        }
      }
    },
    {
      "id": "ai.governance.peer",
      "method": "POST",
      "path": "/mesh/ai-governance/peer",
      "description": "Ingest a peer into the AI governance engine and persist to DB.",
      "auth": "none",
      "request": {
        "contentType": "application/json",
        "body": {
          "id": "string (required)",
          "label": "string (optional)",
          "transport": "ble | wifi | sim (optional)",
          "rssi": "number dBm (optional)",
          "signal": "number 0-100 (optional)",
          "trust": "number 0-100 (optional)",
          "latencyMs": "number (optional)"
        }
      },
      "response": {
        "status": 200,
        "body": {
          "ok": true,
          "peer": "MeshPeer object",
          "snapshot": "AI engine snapshot"
        }
      }
    },
    {
      "id": "ai.governance.send",
      "method": "POST",
      "path": "/mesh/ai-governance/send",
      "description": "Send a governed mesh packet through the AI routing engine. Event persisted to mesh_events.",
      "auth": "none",
      "request": {
        "contentType": "application/json",
        "body": {
          "to": "string peer id (required)",
          "payload": "any (optional)"
        }
      },
      "response": {
        "status": 200,
        "body": {
          "ok": true,
          "result": {
            "packet": "MeshPacket",
            "decision": "string",
            "delivered": "boolean"
          },
          "snapshot": "AI engine snapshot"
        }
      }
    }
  ],
  "databaseTables": {
    "mesh_peers": "Registered mesh peers with transport, signal, trust, jumpCode, lastSeen",
    "mesh_events": "Log of every governed send/receive event",
    "mesh_sessions": "Auth sessions — token, nodeId, username, expiresAt"
  },
  "notes": [
    "Paths must NOT include the /api prefix in route handlers — app.ts already mounts at /api.",
    "All write endpoints are best-effort DB — if DB is unavailable the engine still works in memory.",
    "AES-256-GCM encryption is NOT yet active. Encryption fields in diagnostics must say 'simulation'.",
    "Native BLE requires a physical Android device with the compiled APK — not available in Replit web preview."
  ]
}
