{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "npx --yes pnpm@9.15.4 run typecheck && npx --yes pnpm@9.15.4 -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "tsc --noEmit",
    "qa:run": "mkdir -p qa-results && vitest run --reporter=json --outputFile=qa-results/vitest-results.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "mauri:package:check": "node -e \"const p=require('./package.json'); console.log({expo:p.dependencies?.expo, react:p.dependencies?.react, rn:p.dependencies?.['react-native'], ble:p.dependencies?.['react-native-ble-plx']})\"",
    "mauri:api": "npx --yes pnpm@9.15.4 --filter @workspace/api-server run dev",
    "mauri:dev": "concurrently \"npx --yes pnpm@9.15.4 --filter @workspace/api-server run dev\" \"npx --yes pnpm@9.15.4 --filter @workspace/messenger-mobile run dev\"",
    "mauri:check": "npx --yes pnpm@9.15.4 run typecheck:libs && npx --yes pnpm@9.15.4 --filter @workspace/api-server run typecheck && npx --yes pnpm@9.15.4 --filter @workspace/messenger-mobile run typecheck && echo 'mauri:check PASSED'",
    "check:no-js-ext": "npx --yes pnpm@9.15.4 --filter @workspace/scripts run check-no-js-ext",
    "dev:client": "npx --yes pnpm@9.15.4 --filter @workspace/maurimesh run dev",
    "dev": "tsx server/index.ts",
    "expo:start": "npx expo start --clear --port 8082"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.0",
    "tsx": "latest",
    "@types/react": "~19.1.0",
    "@types/express": "latest",
    "@types/node": "latest"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "latest",
    "expo": "~54.0.35",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-video": "~3.0.16",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-worklets": "0.5.1",
    "react-dom": "19.1.0",
    "react-native-ble-plx": "^3.5.0",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.9",
    "react-native-screens": "~4.16.0",
    "react-native-gesture-handler": "~2.28.0",
    "express": "latest"
  },
  "main": "expo-router/entry",
  "packageManager": "pnpm@9.15.4"
}
